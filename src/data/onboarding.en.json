    {
      "id": "peak_growth_period",
      "type": "choice",
      "question": "During which period did you grow the fastest?",
      "options": [
        "Elementary school",
        "Ages 12–14",
        "Ages 15–17",
        "No noticeable spurt yet",
        "Hard to say"
      ]
    },
    {
      "id": "growth_pauses",
      "type": "choice",
      "question": "Have there been periods when you almost didn't grow (several months or longer)?",
      "options": [
        "Yes, there were long periods without growth",
        "Yes, I sometimes noticed such periods",
        "No, growth was more or less stable",
        "I didn't pay attention"
      ]
    },
    {
      "id": "childhood_height_relative",
      "type": "choice",
