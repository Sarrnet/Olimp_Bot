      "type": "choice",
      "question": "Your gender:",
      "options": [
        "Male",
        "Female"
      ]
    },
    {
      "id": "current_height_cm",
      "type": "input",
      "input_type": "number",
      "question": "What is your current height? Enter a number in centimeters (e.g., 178)."
