{
    "name": "height-olimp-ts",
    "version": "1.0.0",
    "description": "Telegram bot for genetic height growth potential analysis",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "ts-node-dev --respawn src/index.ts",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/index.js",
        "db:generate": "prisma generate",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "telegram",
        "bot",
        "health",
        "fitness"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@mistralai/mistralai": "^1.5.0",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "bullmq": "^5.71.1",
        "canvas": "^3.2.2",
        "dotenv": "^17.3.1",
        "ioredis": "^5.10.1",
        "node-cron": "^4.2.1",
        "openai": "^6.32.0",
        "pg": "^8.20.0",
        "redis": "^5.11.0",
        "telegraf": "^4.16.3",
        "telegraf-ratelimit": "^2.0.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.2",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-v8": "^4.1.1",
        "prettier": "^3.8.1",
        "prettier-plugin-prisma": "^5.0.0",
        "prisma": "^7.5.0",
        "vitest": "^4.1.1"
    }
}
