# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# AI Service (Mistral AI)
AI_API_KEY=your_mistral_api_key_here
AI_MODEL=mistral-medium-latest
AI_BASE_URL=https://api.mistral.ai/v1

# Database Configuration (for Docker)
POSTGRES_USER=olimp_user
POSTGRES_PASSWORD=olimp_password
POSTGRES_DB=olimp_bot

# Prisma Connection URL (used by the app)
# For local dev without docker: postgresql://olimp_user:olimp_password@localhost:5432/olimp_bot?schema=public
# For docker: use the one generated in docker-compose
DATABASE_URL=postgresql://olimp_user:olimp_password@db:5432/olimp_bot?schema=public

# Payment Provider Tokens (from @BotFather)
PAYMENT_TOKEN_YOOKASSA=
PAYMENT_TOKEN_PAYCOM_UZ=
PAYMENT_TOKEN_BEPAID_BY=
PAYMENT_TOKEN_ROBOKASSA_KZ=
PAYMENT_TOKEN_PORTMONE=
PAYMENT_TOKEN_UNLIMIT=

# Admin IDs (comma-separated telegram IDs)
ADMIN_IDS=12345678,87654321

# Redis connection
REDIS_URL=redis://redis:6379

# Bot name for logging
BOT_NAME=HeightOlimpBot
